# ─── LLM Provider ─────────────────────────────────────────────────────────────
# "openai"  → call OpenAI API directly (no GPU needed)
# "local"   → call the llm-service microservice (GPU required)
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Local LLM service (required when LLM_PROVIDER=local)
LLM_SERVICE_URL=http://localhost:8001

# ─── DVWA Target ──────────────────────────────────────────────────────────────
DVWA_BASE_URL=http://modsec.llmshield.click
DVWA_USERNAME=admin
DVWA_PASSWORD=password
DVWA_SECURITY_LEVEL=low

# ─── Defaults ─────────────────────────────────────────────────────────────────
DEFAULT_NUM_PAYLOADS=5
DEFAULT_NUM_DEFENSE_RULES=3
